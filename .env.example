# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL where this app is hosted.
# Used for payment callback/redirect URLs.
APP_URL="http://localhost:3000"

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=kuzama-60de7
FIREBASE_DATABASE_ID=ai-studio-29973ea1-c386-4523-a9d2-0a8c2edd42e5

# Service account JSON (single line, stringified). Production only.
# Locally: run `gcloud auth application-default login` instead.
FIREBASE_SERVICE_ACCOUNT=

# ── Payment Gateways ─────────────────────────────────────────────────────────
# Set ACTIVE_PAYMENT_GATEWAY to whichever gateway you want to use.
# Only credentials for the active gateway are required at startup.
# Values: myfatoorah | thuwani | amwalpay
ACTIVE_PAYMENT_GATEWAY=myfatoorah

# MyFatoorah
MYFATOORAH_API_KEY=
MYFATOORAH_API_URL=https://apitest.myfatoorah.com   # sandbox; use https://api.myfatoorah.com in prod

# Thuwani Pay (Oman)
THUWANI_API_KEY=
THUWANI_PUBLIC_KEY=
THUWANI_API_URL=https://uatcheckout.thuwani.om/api/v1   # sandbox; use https://checkout.thuwani.om/api/v1 in prod

# AmwalPay (Oman)
AMWALPAY_MERCHANT_ID=
AMWALPAY_API_KEY=
AMWALPAY_API_URL=https://sandbox.amwalpay.com/v1   # sandbox; use https://api.amwalpay.com/v1 in prod
AMWALPAY_HMAC_SECRET=
