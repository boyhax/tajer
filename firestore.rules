rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // Prioritize explicit DB lookup, then fallback to hardcoded overrides for bootstrapping
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
          'admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('roles', []))) ||
        (request.auth.token.email == "facegoogl@gmail.com" && request.auth.token.email_verified == true) ||
        request.auth.uid == "o3A0S2cCuHgkiFIycWPtWldGpl03"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===============================================================
    // Validation Helpers
    // ===============================================================
    
    function isValidLocalizedString(data) {
      return data is map && data.get('en', '') is string && data.get('ar', '') is string;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'customer', 'store', 'driver'] &&
             data.roles is list && (data.roles.size() > 0 && data.roles[0] is string) &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidOrder(data) {
      return (data.userId == null || (isSignedIn() && data.userId == request.auth.uid)) &&
             data.status in ['pending', 'processing', 'paid', 'failed', 'shipped', 'delivered'] &&
             data.paymentMethod in ['online', 'cod'] &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0;
    }

    function isValidWishlist(data) {
      return data.userId == request.auth.uid &&
             isValidId(data.productId);
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.brand is string && data.brand.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.categories is list &&
             data.status in ['draft', 'review', 'published', 'rejected'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming()) && 
                       // Protect RBAC fields
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'address', 'addressMode', 'addressDetails', 'defaultLocation', 'language', 'photoURL'])) || 
                    isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isAdmin(); // Assuming only admin manages stores for now, or stores are created by admin
    }

    match /orders/{orderId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isValidOrder(incoming()) && incoming().status in ['pending', 'processing'];
      allow update: if isAdmin() || (isSignedIn() && isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'cancelled' && existing().status == 'pending');
      allow delete: if isAdmin();
    }

    match /wishlist/{wishlistId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWishlist(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow write: if isAdmin();
    }

    match /regions/{regionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /deliveryMethods/{deliveryMethodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
