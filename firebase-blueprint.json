{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item available for purchase in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discount": { "type": "number" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "stock": { "type": "integer" },
        "storeId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "review", "published", "rejected"] },
        "adminMessage": { "type": "string" },
        "hasVariants": { "type": "boolean" },
        "variants": { "type": "array", "items": { "$ref": "#/entities/ProductVariant" } },
        "rating": { "type": "number" },
        "deliveryTime": { "type": "integer" },
        "locals": {
          "type": "object",
          "properties": {
            "name": { "$ref": "#/entities/LocalizedString" },
            "description": { "$ref": "#/entities/LocalizedString" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "brand", "price", "categories", "image", "locals"]
    },
    "ProductVariant": {
      "title": "ProductVariant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "$ref": "#/entities/LocalizedString" },
        "price": { "type": "number" },
        "stock": { "type": "integer" },
        "attributes": { "type": "object" }
      }
    },
    "LocalizedString": {
      "title": "LocalizedString",
      "type": "object",
      "properties": {
        "en": { "type": "string" },
        "ar": { "type": "string" }
      }
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "parentId": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "icon": { "type": "string" },
        "slug": { "type": "string" },
        "bannerImageUrl": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "locals": {
          "type": "object",
          "properties": {
            "title": { "$ref": "#/entities/LocalizedString" },
            "description": { "$ref": "#/entities/LocalizedString" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "isFeatured", "locals", "slug"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "paid", "failed", "shipped", "delivered"] },
        "deliveryStatus": { "type": "string", "enum": ["pending", "assigned", "picked_up", "delivered"] },
        "paymentMethod": { "type": "string", "enum": ["online", "cod"] },
        "driverId": { "type": "string" },
        "storeId": { "type": "string" },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "customerInfo": { "type": "object" }
      },
      "required": ["userId", "items", "totalAmount", "status", "paymentMethod"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer", "store", "driver"] },
        "roles": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "addressMode": { "type": "string" },
        "addressDetails": { "type": "object" },
        "defaultLocation": { "type": "object" },
        "isVerified": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "language": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "roles"]
    },
    "Store": {
      "title": "Store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "logoUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "status": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "adminMessage": { "type": "string" },
        "locals": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "isVerified"]
    },
    "Driver": {
      "title": "Driver",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "vehicleInfo": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "status": { "type": "string" },
        "currentLocation": { "type": "object" },
        "locals": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "vehicleInfo", "isVerified"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "$ref": "#/entities/LocalizedString" },
        "body": { "$ref": "#/entities/LocalizedString" },
        "type": { "type": "string", "enum": ["order_update", "promotion", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["userId", "title", "body", "type", "read"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId"]
    },
    "Region": {
      "title": "Region",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["geozone", "rectangle"] },
        "coordinates": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "coordinates"]
    },
    "DeliveryMethod": {
      "title": "DeliveryMethod",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "priceMatrix": { "type": "object" },
        "isDefault": { "type": "boolean" },
        "isPublished": { "type": "boolean" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "priceMatrix", "isDefault", "isPublished", "categories"]
    },
    "Tag": {
      "title": "Tag",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "$ref": "#/entities/LocalizedString" },
        "icon": { "type": "string" },
        "bannerImage": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "isPromoted": { "type": "boolean" },
        "discountType": { "type": "string" },
        "discountValue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "isPublic"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "type": "object",
      "properties": {
        "paymentMethods": { "type": "object" },
        "restrictDeliveryToRegions": { "type": "boolean" },
        "supportedAddressModes": { "type": "array", "items": { "type": "string" } },
        "appName": { "$ref": "#/entities/LocalizedString" },
        "appDescription": { "$ref": "#/entities/LocalizedString" },
        "socialLinks": { "type": "object" },
        "currency": { "type": "object" }
      }
    },
    "Page": {
      "title": "Page",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "body": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "body"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Collection of all products." },
    "/orders/{orderId}": { "schema": "Order", "description": "Collection of all orders." },
    "/users/{userId}": { "schema": "User", "description": "User profile documents." },
    "/stores/{storeId}": { "schema": "Store", "description": "Collection of all stores." },
    "/drivers/{driverId}": { "schema": "Driver", "description": "Collection of all drivers." },
    "/notifications/{notificationId}": { "schema": "AppNotification", "description": "Collection of all notifications." },
    "/wishlist/{wishlistId}": { "schema": "WishlistItem", "description": "Collection of all wishlist items." },
    "/regions/{regionId}": { "schema": "Region", "description": "Collection of all regions." },
    "/deliveryMethods/{deliveryMethodId}": { "schema": "DeliveryMethod", "description": "Collection of all delivery methods." },
    "/tags/{tagId}": { "schema": "Tag", "description": "Collection of product tags." },
    "/settings/{settingId}": { "schema": "AppSettings", "description": "Global settings documents." },
    "/pages/{pageId}": { "schema": "Page", "description": "CMS pages managed by Puck." }
  }
}
